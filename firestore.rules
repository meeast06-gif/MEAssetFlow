rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules for user profiles
    match /users/{userId} {
      // Allow users to read and write their own profile
      allow read, write: if isOwner(userId);
    }

    // Rules for user assets
    match /users/{userId}/assets/{assetId} {
      // Allow owner to do everything
      allow get, list: if isOwner(userId);
      
      // Allow create if the user is the owner and the userId in the document matches
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      
      // Allow update if the user is the owner and they are not changing the userId
      allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
      
      // Allow delete if the user is the owner
      allow delete: if isOwner(userId);
    }

    // Rules for module inventory
    match /modules/{moduleId}/inventory_list/{inventoryAssetId} {
      // Allow authenticated users to read and write inventory data
      allow read, write: if request.auth != null;
    }
  }
}
